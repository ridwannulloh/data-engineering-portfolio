# Airflow UID (use your user ID on Linux/Mac, or 50000 on Windows)
AIRFLOW_UID=50000

# Airflow Web UI credentials
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Kaggle API token — get yours at https://www.kaggle.com/settings under "API"
# Click "Generate New Token" and copy the token value here
KAGGLE_API_TOKEN=your_kaggle_api_token_here

# Optional: Email configuration for DAG alerts
# AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
# AIRFLOW__SMTP__SMTP_USER=your@email.com
# AIRFLOW__SMTP__SMTP_PASSWORD=your-password
# AIRFLOW__SMTP__SMTP_PORT=587
# AIRFLOW__SMTP__SMTP_MAIL_FROM=your@email.com
