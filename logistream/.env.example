# LogiStream — environment configuration template
# Copy to .env and adjust as needed:
#   cp .env.example .env

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SHIPMENTS=shipment-events
KAFKA_TOPIC_CARRIERS=carrier-updates
KAFKA_TOPIC_WAREHOUSES=warehouse-ops
KAFKA_CONSUMER_GROUP=logistream-spark

# ── Delta Lake paths (local filesystem or HDFS/S3 URI) ────────────────────────
DELTA_BASE_PATH=/tmp/logistream/delta
DELTA_BRONZE_PATH=/tmp/logistream/delta/bronze
DELTA_SILVER_PATH=/tmp/logistream/delta/silver
DELTA_GOLD_PATH=/tmp/logistream/delta/gold

# ── Spark ──────────────────────────────────────────────────────────────────────
SPARK_CHECKPOINT_PATH=/tmp/logistream/checkpoints
SPARK_APP_NAME=LogiStream
SPARK_MASTER=local[*]

# ── SLA thresholds (hours per service tier) ────────────────────────────────────
SLA_STANDARD_HOURS=48
SLA_EXPRESS_HOURS=24
SLA_OVERNIGHT_HOURS=12

# ── FastAPI ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
